{
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": {
            "type": "grafana",
            "uid": "-- Grafana --"
          },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "editable": true,
    "fiscalYearStartMonth": 0,
    "graphTooltip": 0,
    "id": null,
    "links": [],
    "liveNow": false,
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Targets Up (metrics jobs)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(up{job=~\".*_metrics\"})",
            "refId": "A"
          }
        ],
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "none",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          },
          "overrides": []
        }
      },
      {
        "id": 2,
        "type": "timeseries",
        "title": "Request Rate (req/s)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": { "h": 8, "w": 18, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "sum by (service, route) (rate(cafa5_http_requests_total{service=~\"$service\",route=~\"$route\",status_code=~\"$status_code\"}[5m]))",
            "legendFormat": "{{service}} {{route}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "reqps" },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
      },
      {
        "id": 3,
        "type": "timeseries",
        "title": "Error Ratio (5xx / total)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
        "targets": [
          {
            "expr": "sum(rate(cafa5_http_requests_total{service=~\"$service\",route=~\"$route\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(cafa5_http_requests_total{service=~\"$service\",route=~\"$route\"}[5m])), 1e-9)",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      },
      {
        "id": 4,
        "type": "timeseries",
        "title": "P95 Latency (s)",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum by (le, service, route) (rate(cafa5_http_request_duration_seconds_bucket{service=~\"$service\",route=~\"$route\",status_code=~\"$status_code\"}[5m])))",
            "legendFormat": "{{service}} {{route}} p95",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "s" },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "table", "placement": "bottom" } }
      },
      {
        "id": 5,
        "type": "timeseries",
        "title": "In-flight Requests",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
        "targets": [
          {
            "expr": "sum by (service) (cafa5_http_in_flight_requests{service=~\"$service\"})",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": { "unit": "none", "min": 0 },
          "overrides": []
        },
        "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
      }
    ],
    "refresh": "30s",
    "schemaVersion": 39,
    "style": "dark",
    "tags": ["cafa5", "operations", "http"],
    "templating": {
      "list": [
        {
          "name": "service",
          "type": "query",
          "label": "Service",
          "hide": 0,
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "definition": "label_values(cafa5_http_requests_total, service)",
          "query": {
            "query": "label_values(cafa5_http_requests_total, service)",
            "refId": "ServiceVar"
          },
          "multi": true,
          "includeAll": true,
          "allValue": ".*",
          "current": { "text": "All", "value": ".*" }
        },
        {
          "name": "route",
          "type": "query",
          "label": "Route",
          "hide": 0,
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "definition": "label_values(cafa5_http_requests_total{service=~\"$service\"}, route)",
          "query": {
            "query": "label_values(cafa5_http_requests_total{service=~\"$service\"}, route)",
            "refId": "RouteVar"
          },
          "multi": true,
          "includeAll": true,
          "allValue": ".*",
          "current": { "text": "All", "value": ".*" }
        },
        {
          "name": "status_code",
          "type": "query",
          "label": "Status Code",
          "hide": 0,
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "definition": "label_values(cafa5_http_requests_total{service=~\"$service\",route=~\"$route\"}, status_code)",
          "query": {
            "query": "label_values(cafa5_http_requests_total{service=~\"$service\",route=~\"$route\"}, status_code)",
            "refId": "StatusVar"
          },
          "multi": true,
          "includeAll": true,
          "allValue": ".*",
          "current": { "text": "All", "value": ".*" }
        }
      ]
    },
    "time": { "from": "now-6h", "to": "now" },
    "timepicker": {},
    "timezone": "",
    "title": "CAFA5 Service Health",
    "uid": "cafa5-service-health",
    "version": 1,
    "weekStart": ""
  }