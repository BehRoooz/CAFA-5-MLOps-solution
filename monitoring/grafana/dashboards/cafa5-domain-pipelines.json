        "targets": [
          {
            "expr": "sum(rate(cafa5_inference_requests_total{model_version=~\"$model_version\",status_code=~\"5..\"}[5m])) / clamp_min(sum(rate(cafa5_inference_requests_total{model_version=~\"$model_version\"}[5m])), 1e-9)",
