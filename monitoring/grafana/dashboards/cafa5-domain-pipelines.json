        "title": "Embedding Queue Depth by Status",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 2 },
        "targets": [
          {
            "expr": "sum by (status) (cafa5_embedding_queue_jobs)",
            "legendFormat": "{{status}}",
            "refId": "A"
