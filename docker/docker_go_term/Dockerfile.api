FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONPATH=/app:/app/services/go-prediction-api

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    tini \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/
RUN pip install --upgrade pip setuptools wheel && \
    pip install -r /app/requirements.txt

COPY src /app/src
COPY services/go-prediction-api /app/services/go-prediction-api
RUN mkdir -p /app/model_cache /app/outputs

ENTRYPOINT ["/usr/bin/tini", "--"]
CMD ["python", "-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--app-dir", "/app/services/go-prediction-api"]
